      label: {
        de: 'Mobilität & Verkehr',
        fr: 'Mobilité & transports',
        it: 'Mobilità & trasporti',
        en: 'Mobility & transport',
      },
      children: [
        'ch.bav.haltestellen-oev',
        'ch.swisstopo.swisstlm3d-wanderwege',
