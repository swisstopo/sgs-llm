// Curated layer tree for the SGS LLM map catalog.
//
// Children are bare Swisstopo layer ids (`layerBodId`); their display labels,
// tile parameters, and attribution are resolved at runtime from the
// api3.geo.admin.ch layersConfig endpoint, so this file never duplicates
// official metadata. Group labels are inline and multilingual.
{
  groups: [
    {
      id: 'environment',
      label: {
        de: 'Umwelt & Natur',
        fr: 'Environnement & nature',
        it: 'Ambiente & natura',
        en: 'Environment & nature',
      },
      children: [
        'ch.bafu.waldreservate',
        'ch.bafu.wrz-wildruhezonen_portal',
        'ch.bafu.bundesinventare-bln',
        'ch.bafu.landesforstinventar-vegetationshoehenmodell',
        'ch.bafu.hydrologie-gewaesserzustandsmessstationen',
      ],
    },
    {
