{
  "name": "sgs-llm-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "Chat + web map frontend for the SGS LLM prototype",
  "license": "BSD-3-Clause",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint src",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@lit/context": "^1.1.6",
    "@lit/task": "^1.0.3",
    "@swissgeol/ui-core": "1.6.0",
    "dompurify": "^3.4.8",
    "i18next": "^26.3.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "json5": "^2.2.3",
    "lit": "^3.3.3",
    "marked": "^15.0.7",
    "ol": "^10.9.0",
    "proj4": "^2.20.9",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@types/proj4": "^2.5.6",
    "eslint": "^9.39.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-lit": "^2.3.1",
    "prettier": "^3.8.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^7.3.1",
    "vite-plugin-static-copy": "^4.1.1",
    "vitest": "^4.1.8"
  }
}
